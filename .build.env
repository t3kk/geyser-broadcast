# Version Tracking for Geyser Docker Builds
# This file tracks the versions used in the current build
# Updated automatically by GitHub Actions CI/CD pipeline

# Eclipse Temurin version (must be LTS)
# Current LTS versions: 8, 11, 17, 21, 23+
TEMURIN_VERSION=21-jdk-alpine

# Geyser latest release
# Repository: https://github.com/GeyserMC/Geyser
# Note: Actual version (2.9.5) extracted from download API redirect
GEYSER_VERSION=2.9.5
GEYSER_DOWNLOAD_URL=https://download.geysermc.org/v2/projects/geyser/versions/latest/builds/latest/downloads/standalone

# MCXboxBroadcast latest release  
# Repository: https://github.com/MCXboxBroadcast/Broadcaster
XBOX_BROADCAST_VERSION=134
XBOX_BROADCAST_DOWNLOAD_URL=https://github.com/MCXboxBroadcast/Broadcaster/releases/download/134/MCXboxBroadcastExtension.jar

